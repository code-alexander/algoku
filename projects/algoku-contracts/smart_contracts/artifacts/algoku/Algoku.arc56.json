                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Mints an NFT for a valid, unique sudoku solution.\nEach unique solution can only be minted once \u2014 uniqueness is enforced by a box keyed on sha256(solution). The minted NFT encodes (solution || mask) in its URL field and records the solver address in its reserve field; claim() later transfers to the address stored there.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "claim",
            "args": [
                {
                    "type": "uint64",
                    "name": "asset"
