            "returns": {
                "type": "void"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Transfers a minted NFT to the address recorded in its reserve field.\nThe reserve field is set at mint time to the solver's address, so this method is self-authorizing \u2014 it always sends the asset to its intended recipient regardless of who calls it. Caller must ensure the recipient has already opted in to the asset.",
            "events": [],
            "recommendations": {}
        }
